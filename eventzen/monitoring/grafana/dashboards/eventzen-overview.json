{
  "title": "EventZen Platform Overview",
  "uid": "eventzen-overview",
  "description": "Real-time monitoring dashboard for all EventZen microservices",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["eventzen", "microservices", "monitoring"],
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Service Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Auth Service",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "up{job=\"auth-service\"}", "legendFormat": "Auth Service", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Event Service",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "up{job=\"event-service\"}", "legendFormat": "Event Service", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Venue/Vendor Service",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "up{job=\"venue-vendor-service\"}", "legendFormat": "Venue/Vendor Service", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Ticketing Service",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "up{job=\"ticketing-service\"}", "legendFormat": "Ticketing Service", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Finance Service",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "up{job=\"finance-service\"}", "legendFormat": "Finance Service", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Notification Service",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "up{job=\"notification-service\"}", "legendFormat": "Notification Service", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 8,
      "type": "row",
      "title": "HTTP Traffic",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP Request Rate (req/sec)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total[5m]))",
          "legendFormat": "{{job}} (Node.js)",
          "refId": "A"
        },
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_count[5m]))",
          "legendFormat": "{{job}} (Spring Boot)",
          "refId": "B"
        },
        {
          "expr": "sum by (job) (rate(http_requests_received_total[5m]))",
          "legendFormat": "{{job}} (.NET)",
          "refId": "C"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP Error Rate (5xx/sec)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": [{ "matcher": { "id": "byRegexp", "options": ".*" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }]
      },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "{{job}} (Node.js 5xx)",
          "refId": "A"
        },
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]))",
          "legendFormat": "{{job}} (Spring 5xx)",
          "refId": "B"
        },
        {
          "expr": "sum by (job) (rate(http_requests_received_total{code=~\"5..\"}[5m]))",
          "legendFormat": "{{job}} (.NET 5xx)",
          "refId": "C"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 11,
      "type": "row",
      "title": "Request Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP P99 Latency (Node.js services)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 - {{job}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 - {{job}}",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "HTTP P99 Latency (Spring Boot event-service)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (uri, le) (rate(http_server_requests_seconds_bucket{job=\"event-service\"}[5m])))",
          "legendFormat": "p99 {{uri}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 14,
      "type": "row",
      "title": "Runtime Memory",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Node.js Heap Used (MB)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "decmbytes"
        }
      },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"auth-service\"} / 1024 / 1024",
          "legendFormat": "auth-service",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"venue-vendor-service\"} / 1024 / 1024",
          "legendFormat": "venue-vendor-service",
          "refId": "B"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"notification-service\"} / 1024 / 1024",
          "legendFormat": "notification-service",
          "refId": "C"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "JVM Heap Used (MB) — event-service",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "decmbytes"
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"event-service\", area=\"heap\"} / 1024 / 1024",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{job=\"event-service\", area=\"heap\"} / 1024 / 1024",
          "legendFormat": "Heap Max",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": ".NET Process Memory (MB)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "decmbytes"
        }
      },
      "targets": [
        {
          "expr": "process_working_set_bytes{job=\"ticketing-service\"} / 1024 / 1024",
          "legendFormat": "ticketing-service",
          "refId": "A"
        },
        {
          "expr": "process_working_set_bytes{job=\"finance-service\"} / 1024 / 1024",
          "legendFormat": "finance-service",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 18,
      "type": "row",
      "title": "Container Metrics (cAdvisor)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Container CPU Usage (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"eventzen-.*-service\"}[5m])) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Container Memory Usage (MB)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "decmbytes"
        }
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"eventzen-.*-service\"} / 1024 / 1024",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 21,
      "type": "row",
      "title": "Host Metrics (Node Exporter)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 }
    },
    {
      "id": 22,
      "type": "gauge",
      "title": "Host CPU Usage",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 42 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 23,
      "type": "gauge",
      "title": "Host Memory Usage",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 42 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "100 - ((node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100)",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Network I/O (bytes/sec)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "Bps"
        }
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*\"}[5m])",
          "legendFormat": "RX {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*\"}[5m])",
          "legendFormat": "TX {{device}}",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 25,
      "type": "row",
      "title": "Node.js Event Loop & GC",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 }
    },
    {
      "id": 26,
      "type": "timeseries",
      "title": "Event Loop Lag (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{job=\"auth-service\"} * 1000",
          "legendFormat": "auth-service",
          "refId": "A"
        },
        {
          "expr": "nodejs_eventloop_lag_seconds{job=\"venue-vendor-service\"} * 1000",
          "legendFormat": "venue-vendor-service",
          "refId": "B"
        },
        {
          "expr": "nodejs_eventloop_lag_seconds{job=\"notification-service\"} * 1000",
          "legendFormat": "notification-service",
          "refId": "C"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 27,
      "type": "timeseries",
      "title": "Active Handles (Node.js)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 51 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "nodejs_active_handles_total{job=\"auth-service\"}",
          "legendFormat": "auth-service",
          "refId": "A"
        },
        {
          "expr": "nodejs_active_handles_total{job=\"venue-vendor-service\"}",
          "legendFormat": "venue-vendor-service",
          "refId": "B"
        },
        {
          "expr": "nodejs_active_handles_total{job=\"notification-service\"}",
          "legendFormat": "notification-service",
          "refId": "C"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "timepicker": {}
}
