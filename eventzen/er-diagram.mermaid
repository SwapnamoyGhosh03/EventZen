  init: {
    "theme": "default",
    "er": {
      "diagramPadding": 40,
      "layoutDirection": "TB",
      "minEntityWidth": 100,
      "minEntityHeight": 75,
      "entityPadding": 15,
      "useMaxWidth": true
    }
  }
}%%

erDiagram

%% ╔══════════════════════════════════════════════════════════════════════════════╗
%% ║  EVENTZEN — UNIFIED ER DIAGRAM                                             ║
%% ║  Polyglot Persistence: MySQL (3 services) + MongoDB (3 services)           ║
%% ║                                                                             ║
%% ║  Legend:                                                                    ║
%% ║    AUTH_*   → MySQL  · eventzen_auth       (Knex.js / Node.js)             ║
%% ║    EVT_*    → MySQL  · eventzen_events     (Spring Boot JPA)               ║
%% ║    FIN_*    → MySQL  · eventzen_finance    (.NET EF Core)                  ║
%% ║    VV_*     → MongoDB · eventzen_venue     (Mongoose / Node.js)            ║
%% ║    TKT_*    → MongoDB · eventzen_ticketing (.NET / MongoDB Driver)         ║
%% ║    NOTIF_*  → MongoDB · eventzen_notifications (Mongoose / Node.js)        ║
%% ║                                                                             ║
%% ║  Relationship labels ending with "(logical)" are cross-service references. ║
%% ║  They are enforced at the application layer, NOT as database foreign keys. ║
%% ╚══════════════════════════════════════════════════════════════════════════════╝


%% ═════════════════════════════════════════════════════════════════════════════
%%  AUTH SERVICE  ·  MySQL · eventzen_auth  ·  Knex.js / Node.js
%% ═════════════════════════════════════════════════════════════════════════════

    AUTH_users {
        uuid        user_id                    PK  "DEFAULT uuid()"
        varchar255  email                      UK  "UNIQUE NOT NULL"
        varchar255  password_hash                  "NOT NULL bcrypt"
        varchar100  first_name                     "NOT NULL"
        varchar100  last_name                      "NOT NULL"
        varchar50   phone                          "nullable"
        varchar500  avatar_url                     "nullable"
        boolean     is_email_verified              "DEFAULT false"
        boolean     is_mfa_enabled                 "DEFAULT false"
        varchar255  mfa_secret                     "nullable TOTP"
        enum        status                         "ACTIVE|INACTIVE|SUSPENDED|PENDING_VERIFICATION"
        varchar255  email_verification_token       "nullable"
        timestamp   email_verification_expires     "nullable"
        varchar255  password_reset_token           "nullable"
        timestamp   password_reset_expires         "nullable"
        varchar255  google_id                   UK  "nullable OAuth"
        timestamp   created_at                     "DEFAULT CURRENT_TIMESTAMP"
        timestamp   updated_at                     "AUTO ON UPDATE"
        timestamp   deleted_at                     "nullable soft-delete"
    }

    AUTH_roles {
        uuid        role_id                    PK  "DEFAULT uuid()"
        varchar50   role_name                  UK  "ADMIN|ORGANIZER|VENDOR|ATTENDEE"
        varchar255  description                    "nullable"
        timestamp   created_at
        timestamp   updated_at
    }

    AUTH_permissions {
        uuid        permission_id              PK  "DEFAULT uuid()"
        varchar50   module                         "event|venue|vendor|ticket|budget|user|report|notification"
        varchar50   action                         "create|read|update|delete|approve|export"
        varchar50   resource_type                  "nullable"
        varchar255  description                    "nullable"
        timestamp   created_at
        timestamp   updated_at
    }

    AUTH_user_roles {
        uuid        id                         PK  "DEFAULT uuid()"
        uuid        user_id                    FK  "-> AUTH_users CASCADE DELETE"
        uuid        role_id                    FK  "-> AUTH_roles CASCADE DELETE"
        uuid        assigned_by                    "nullable -> AUTH_users (admin)"
        timestamp   assigned_at                    "DEFAULT CURRENT_TIMESTAMP"
    }

    AUTH_role_permissions {
        uuid        id                         PK  "DEFAULT uuid()"
        uuid        role_id                    FK  "-> AUTH_roles CASCADE DELETE"
        uuid        permission_id              FK  "-> AUTH_permissions CASCADE DELETE"
    }

    AUTH_refresh_tokens {
        uuid        token_id                   PK  "DEFAULT uuid()"
        uuid        user_id                    FK  "-> AUTH_users CASCADE DELETE"
        varchar255  token_hash                 UK  "hashed token"
        varchar255  family_id                      "rotation chain ID"
        timestamp   expires_at                     "NOT NULL"
        boolean     revoked                        "DEFAULT false"
        varchar45   ip_address                     "nullable IPv4/IPv6"
        varchar500  user_agent                     "nullable"
        timestamp   created_at
        timestamp   updated_at
    }

    AUTH_account_requests {
        uuid        request_id                 PK  "DEFAULT uuid()"
        uuid        user_id                    FK  "-> AUTH_users nullable"
        enum        type                           "VENDOR_ACCESS|DEACTIVATE|REACTIVATE|GDPR_DELETE"
        enum        status                         "PENDING|APPROVED|REJECTED|CANCELLED"
        text        reason                         "nullable user-provided"
        text        admin_notes                    "nullable review notes"
        uuid        reviewed_by                    "nullable -> AUTH_users (admin)"
        timestamp   reviewed_at                    "nullable"
        varchar255  email_for_reactivation         "nullable"
        timestamp   created_at
        timestamp   updated_at
    }

    AUTH_audit_log {
        bigint      log_id                     PK  "AUTO_INCREMENT"
        uuid        user_id                    FK  "-> AUTH_users SET NULL"
        varchar100  action                         "NOT NULL e.g. USER_LOGIN"
        varchar50   resource_type                  "NOT NULL e.g. User"
        varchar100  resource_id                    "nullable entity PK"
        json        old_value                      "nullable before state"
        json        new_value                      "nullable after state"
        varchar45   ip_address                     "nullable"
        varchar500  user_agent                     "nullable"
        timestamp   created_at                     "DEFAULT CURRENT_TIMESTAMP"
    }


%% ═════════════════════════════════════════════════════════════════════════════
%%  EVENT SERVICE  ·  MySQL · eventzen_events  ·  Spring Boot JPA / Hibernate
%% ═════════════════════════════════════════════════════════════════════════════

    EVT_events {
        varchar36   eventId                    PK  "UUID string"
        varchar255  title                          "NOT NULL"
        text        description                    "nullable"
        varchar500  shortDescription               "nullable listing blurb"
        varchar500  bannerUrl                      "nullable CDN URL"
        longtext    imageUrls                      "JSON array via StringListConverter"
        varchar36   organizerId                    "NOT NULL — logical ref AUTH_users"
        varchar36   categoryId                 FK  "-> EVT_event_categories nullable"
        enum        status                         "DRAFT|PUBLISHED|ONGOING|COMPLETED|CANCELLED"
        varchar100  eventType                      "nullable classification"
        datetime    startDate                      "nullable"
        datetime    endDate                        "nullable"
        varchar50   timezone                       "DEFAULT UTC"
        varchar36   venueId                        "nullable — logical ref VV_venues"
        varchar100  city                           "nullable"
        text        address                        "nullable full address"
        int         maxCapacity                    "DEFAULT 0"
        int         currentRegistrations           "DEFAULT 0"
        boolean     isRecurring                    "DEFAULT false"
        varchar255  recurrenceRule                 "nullable RFC 5545 iCal RRULE"
        boolean     isFree                         "DEFAULT true"
        decimal10_2 basePrice                      "DEFAULT 0.00"
        varchar3    currency                       "DEFAULT INR ISO 4217"
        timestamp   createdAt                      "NOT NULL auto"
        timestamp   updatedAt                      "NOT NULL auto-updated"
        timestamp   deletedAt                      "nullable soft-delete"
    }

    EVT_event_categories {
        varchar36   categoryId                 PK  "UUID string"
        varchar100  categoryName               UK  "UNIQUE NOT NULL"
        varchar50   icon                           "nullable icon identifier"
        varchar7    color                          "nullable hex #RRGGBB"
        text        description                    "nullable"
        int         sortOrder                      "DEFAULT 0 display order"
        timestamp   createdAt
        timestamp   updatedAt
    }

    EVT_event_sessions {
        varchar36   sessionId                  PK  "UUID string"
        varchar36   eventId                    FK  "-> EVT_events CASCADE"
        varchar255  title                          "NOT NULL"
        text        description                    "nullable"
        varchar200  speakerName                    "nullable"
        varchar36   speakerId                      "nullable — logical ref AUTH_users"
        varchar100  room                           "nullable hall/room name"
        varchar100  sessionType                    "TALK|WORKSHOP|PANEL|KEYNOTE|etc."
        datetime    startTime                      "nullable"
        datetime    endTime                        "nullable"
        int         capacity                       "DEFAULT 0"
        int         sortOrder                      "DEFAULT 0"
        timestamp   createdAt
        timestamp   updatedAt
    }

    EVT_event_agenda {
        varchar36   agendaId                   PK  "UUID string"
        varchar36   eventId                    FK  "-> EVT_events CASCADE"
        varchar36   sessionId                  FK  "-> EVT_event_sessions nullable"
        varchar255  title                          "NOT NULL"
        text        description                    "nullable"
        datetime    startTime                      "nullable"
        datetime    endTime                        "nullable"
        int         sortOrder                      "DEFAULT 0"
        varchar100  type                           "SESSION|BREAK|MEAL|KEYNOTE|NETWORKING"
        timestamp   createdAt
        timestamp   updatedAt
    }

    EVT_event_tags {
        varchar36   id                         PK  "UUID string"
        varchar36   eventId                    FK  "-> EVT_events CASCADE"
        varchar50   tagName                        "NOT NULL"
    }


%% ═════════════════════════════════════════════════════════════════════════════
%%  VENUE-VENDOR SERVICE  ·  MongoDB · eventzen_venue  ·  Mongoose / Node.js
%% ═════════════════════════════════════════════════════════════════════════════

    VV_venues {
        ObjectId    _id                        PK  "MongoDB auto ObjectId"
        String      name                           "Required trimmed"
        String      description                    "nullable"
        Object      address                        "street|city|state|country|zip"
        Object      location                       "GeoJSON Point [lng,lat] 2dsphere index"
        Number      total_capacity                 "Required"
        Array       halls                          "hall_id|name|capacity|amenities|hourly_rate|floor"
        Array       amenities                      "WiFi|Parking|AV|Catering|etc."
        Array       media_gallery                  "url|caption|type(image/video)"
        Object      pricing                        "base_rate|currency|pricing_model"
        Object      contact                        "name|email|phone"
        Boolean     is_active                      "DEFAULT true"
        Number      rating_average                 "DEFAULT 0 aggregated 1-5"
        Number      rating_count                   "DEFAULT 0"
        String      created_by                     "logical ref AUTH_users"
        Date        createdAt
        Date        updatedAt
    }

    VV_vendors {
        ObjectId    _id                        PK  "MongoDB auto ObjectId"
        String      vendor_id                  UK  "Unique business identifier"
        String      name                           "Required trimmed"
        String      description                    "nullable"
        String      service_type                   "CATERING|AV|DECOR|SECURITY|PHOTOGRAPHY|ENTERTAINMENT|LOGISTICS|OTHER"
        Array       service_packages               "package_id|name|description|price|currency"
        Object      contact                        "name|email|phone"
        Array       portfolio_urls                 "nullable website/portfolio links"
        Number      rating_average                 "DEFAULT 0 aggregated 1-5"
        Number      rating_count                   "DEFAULT 0"
        Array       reviews                        "reviewer_id|rating(1-5)|comment|created_at"
        Boolean     is_active                      "DEFAULT true"
        Date        createdAt
        Date        updatedAt
    }

    VV_venue_bookings {
        ObjectId    _id                        PK  "MongoDB auto ObjectId"
        String      booking_id                 UK  "Unique booking ref"
        ObjectId    venue_id                   FK  "-> VV_venues"
        String      hall_id                        "nullable specific hall within venue"
        String      event_id                       "logical ref EVT_events"
        String      organizer_id                   "logical ref AUTH_users"
        Date        booking_start                  "Required"
        Date        booking_end                    "Required"
        String      status                         "PENDING|CONFIRMED|CANCELLED"
        Number      total_cost                     "nullable computed INR"
        String      notes                          "nullable"
        Date        createdAt
        Date        updatedAt
    }

    VV_event_vendors {
        ObjectId    _id                        PK  "MongoDB auto ObjectId"
        String      contract_id                UK  "Unique contract ref"
        String      event_id                       "logical ref EVT_events"
        String      vendor_id                      "logical ref VV_vendors.vendor_id"
        String      service_description            "nullable"
        Number      agreed_price                   "Required INR"
        String      currency                       "DEFAULT INR"
        String      status                         "PENDING|SIGNED|ACTIVE|COMPLETED|CANCELLED"
        Date        signed_at                      "nullable"
        Array       version_history                "version|status|changed_by|changed_at|notes"
        String      created_by                     "logical ref AUTH_users"
        Date        createdAt
        Date        updatedAt
    }


%% ═════════════════════════════════════════════════════════════════════════════
%%  TICKETING SERVICE  ·  MongoDB · eventzen_ticketing  ·  .NET / MongoDB Driver
%% ═════════════════════════════════════════════════════════════════════════════

    TKT_ticket_types {
        ObjectId    _id                        PK  "MongoDB BsonId"
        String      ticketTypeId               UK  "GUID default"
        String      eventId                        "logical ref EVT_events"
        String      organizerId                    "logical ref AUTH_users nullable"
        String      name                           "Required display name"
        String      type                           "GENERAL|VIP|SPEAKER|SPONSOR"
        Decimal     price                          "Required"
        String      currency                       "DEFAULT USD"
        Int32       totalQuantity                  "Required total stock"
        Int32       availableQuantity              "Required remaining"
        Int32       maxPerUser                     "DEFAULT 1"
        DateTime    saleStart                      "Required"
        DateTime    saleEnd                        "Required"
        String      description                    "nullable"
        String      seatMapImageUrl                "nullable"
        Boolean     isActive                       "DEFAULT true"
        DateTime    createdAt                      "DEFAULT UtcNow"
        DateTime    updatedAt                      "DEFAULT UtcNow"
    }

    TKT_registrations {
        ObjectId    _id                        PK  "MongoDB BsonId"
        String      registrationId             UK  "GUID default"
        String      eventId                        "logical ref EVT_events"
        String      attendeeId                     "logical ref AUTH_users"
        String      attendeeName                   "denormalized nullable"
        String      attendeeEmail                  "denormalized nullable"
        String      ticketTypeId               FK  "-> TKT_ticket_types"
        String      ticketId                       "logical ref TKT_tickets nullable"
        String      idempotencyKey                 "Required duplicate-prevention"
        String      status                         "CONFIRMED|CANCELLED|WAITLISTED"
        String      paymentId                      "logical ref FIN_payments nullable"
        Decimal     amountPaid                     "Required"
        DateTime    registeredAt                   "DEFAULT UtcNow"
        DateTime    cancelledAt                    "nullable"
        String      cancellationReason             "nullable"
    }

    TKT_tickets {
        ObjectId    _id                        PK  "MongoDB BsonId"
        String      ticketId                   UK  "GUID default"
        String      registrationId             FK  "-> TKT_registrations"
        String      eventId                        "logical ref EVT_events"
        String      attendeeId                     "logical ref AUTH_users"
        String      ticketTypeId               FK  "-> TKT_ticket_types"
        String      ticketType                     "GENERAL|VIP|SPEAKER|SPONSOR"
        String      eventTitle                     "denormalized nullable"
        String      eventDate                      "denormalized nullable"
        String      eventCity                      "denormalized nullable"
        String      qrCodeData                     "Required HMAC-signed payload"
        String      status                         "ACTIVE|USED|CANCELLED|EXPIRED"
        String      bookingGroupId                 "nullable group booking ref"
        Int32       groupQuantity                  "nullable tickets in group"
        DateTime    checkedInAt                    "nullable"
        DateTime    createdAt                      "DEFAULT UtcNow"
    }

    TKT_checkin_logs {
        ObjectId    _id                        PK  "MongoDB BsonId"
        String      registrationId             FK  "-> TKT_registrations"
        String      ticketId                   FK  "-> TKT_tickets"
        String      eventId                        "logical ref EVT_events"
        String      attendeeId                     "logical ref AUTH_users"
        String      staffId                        "logical ref AUTH_users (scanner)"
        String      gate                           "Required entrance identifier"
        DateTime    checkinTime                    "DEFAULT UtcNow"
        String      method                         "QR_SCAN|MANUAL"
    }

    TKT_waitlists {
        ObjectId    _id                        PK  "MongoDB BsonId"
        String      waitlistId                 UK  "GUID default"
        String      eventId                        "logical ref EVT_events"
        String      attendeeId                     "logical ref AUTH_users"
        String      ticketTypeId               FK  "-> TKT_ticket_types"
        Int32       position                       "Required queue position"
        DateTime    joinTime                       "DEFAULT UtcNow"
        String      status                         "WAITING|PROMOTED|EXPIRED|CANCELLED"
        DateTime    promotedAt                     "nullable"
        DateTime    promotionExpiresAt             "nullable offer window"
    }

    TKT_feedbacks {
        ObjectId    _id                        PK  "MongoDB BsonId"
        String      feedbackId                 UK  "GUID default"
        String      eventId                        "logical ref EVT_events"
        String      attendeeId                     "logical ref AUTH_users"
        Int32       eventRating                    "Required 1-5"
        Int32       vendorRating                   "Required 1-5"
        Int32       platformRating                 "Required 1-5"
        String      eventComment                   "nullable"
        String      vendorComment                  "nullable"
        String      platformComment                "nullable"
        Boolean     isShowcased                    "DEFAULT false"
        DateTime    createdAt                      "DEFAULT UtcNow"
        DateTime    updatedAt                      "DEFAULT UtcNow"
    }


%% ═════════════════════════════════════════════════════════════════════════════
%%  FINANCE SERVICE  ·  MySQL · eventzen_finance  ·  .NET EF Core / MySQL
%% ═════════════════════════════════════════════════════════════════════════════

    FIN_budgets {
        String      BudgetId                   PK  "GUID"
        String      EventId                        "logical ref EVT_events"
        String      CreatedBy                      "logical ref AUTH_users"
        String      Title                          "Required"
        Decimal     TotalEstimated                 "Required running total"
        Decimal     TotalApproved                  "Required approved ceiling"
        Decimal     TotalActual                    "Required spent to date"
        String      Currency                       "DEFAULT INR"
        String      Status                         "DRAFT|PENDING_APPROVAL|APPROVED|CLOSED"
        String      ApprovedBy                     "nullable logical ref AUTH_users"
        DateTime    ApprovedAt                     "nullable"
        String      Notes                          "nullable"
        DateTime    CreatedAt                      "DEFAULT UtcNow"
        DateTime    UpdatedAt                      "DEFAULT UtcNow"
    }

    FIN_budget_items {
        String      ItemId                     PK  "GUID"
        String      BudgetId                   FK  "-> FIN_budgets"
        String      Category                       "VENUE|CATERING|AV|MARKETING|STAFF|DECOR|SECURITY|LOGISTICS|OTHER"
        String      Description                    "Required line-item label"
        Decimal     EstimatedAmount                "Required"
        Decimal     ActualAmount                   "Required 0 until invoiced"
        String      Notes                          "nullable"
        DateTime    CreatedAt                      "DEFAULT UtcNow"
        DateTime    UpdatedAt                      "DEFAULT UtcNow"
    }

    FIN_expenses {
        String      ExpenseId                  PK  "GUID"
        String      EventId                        "logical ref EVT_events"
        String      BudgetId                   FK  "-> FIN_budgets nullable"
        String      Category                       "VENUE|CATERING|AV|MARKETING|STAFF|DECOR|SECURITY|LOGISTICS|OTHER"
        String      Description                    "Required"
        Decimal     Amount                         "Required"
        String      Currency                       "DEFAULT INR"
        String      ReceiptUrl                     "nullable S3/MinIO URL"
        String      SubmittedBy                    "logical ref AUTH_users"
        String      ApprovedBy                     "nullable logical ref AUTH_users"
        String      Status                         "SUBMITTED|APPROVED|REJECTED"
        DateTime    CreatedAt                      "DEFAULT UtcNow"
        DateTime    UpdatedAt                      "DEFAULT UtcNow"
    }

    FIN_payments {
        String      PaymentId                  PK  "GUID"
        String      EventId                        "logical ref EVT_events"
        String      UserId                         "logical ref AUTH_users (payer)"
        String      RegistrationId                 "nullable logical ref TKT_registrations"
        Decimal     Amount                         "Required"
        String      Currency                       "DEFAULT INR"
        String      Status                         "PENDING|COMPLETED|FAILED|REFUNDED"
        String      PaymentMethod                  "STRIPE|RAZORPAY|EVENTZEN"
        String      GatewayPaymentId               "nullable txn ID from gateway"
        String      GatewayResponse                "nullable JSON webhook payload"
        String      Description                    "nullable"
        DateTime    PaidAt                         "nullable completion ts"
        DateTime    CreatedAt                      "DEFAULT UtcNow"
        DateTime    UpdatedAt                      "DEFAULT UtcNow"
    }

    FIN_sponsorships {
        String      SponsorshipId              PK  "GUID"
        String      EventId                        "logical ref EVT_events"
        String      VendorId                       "logical ref VV_vendors.vendor_id"
        String      CompanyName                    "Required"
        String      LogoUrl                        "nullable CDN URL"
        String      Message                        "nullable"
        Decimal     Amount                         "Required INR"
        DateTime    CreatedAt                      "DEFAULT UtcNow"
    }


%% ═════════════════════════════════════════════════════════════════════════════
%%  NOTIFICATION SERVICE  ·  MongoDB · eventzen_notifications  ·  Mongoose
%% ═════════════════════════════════════════════════════════════════════════════

    NOTIF_notifications {
        ObjectId    _id                        PK  "MongoDB auto ObjectId"
        String      notification_id            UK  "Unique UUID"
        String      user_id                        "logical ref AUTH_users (recipient)"
        String      title                          "Required"
        String      body                           "Required"
        String      type                           "registration_confirmed|ticket_ready|event_reminder|vendor_response|etc."
        String      channel                        "EMAIL|SMS|PUSH|IN_APP|WEBHOOK"
        String      status                         "PENDING|SENT|DELIVERED|FAILED|READ"
        Mixed       data                           "nullable arbitrary JSON payload"
        Date        read_at                        "null=unread nullable"
        Date        created_at                     "DEFAULT now indexed"
        Date        expires_at                     "nullable TTL index"
        Boolean     deleted                        "DEFAULT false soft-delete"
    }

    NOTIF_templates {
        ObjectId    _id                        PK  "MongoDB auto ObjectId"
        String      template_key               UK  "Unique e.g. registration_confirmed_email"
        String      channel                        "Required EMAIL|SMS|PUSH"
        String      subject                        "nullable email subject line"
        String      body                           "Required Handlebars template"
        Array       variables                      "placeholder names e.g. {{eventName}}"
        Array       versions                       "version|body|updated_by|updated_at"
        Boolean     is_active                      "DEFAULT true"
        Date        createdAt
        Date        updatedAt
    }

    NOTIF_delivery_logs {
        ObjectId    _id                        PK  "MongoDB auto ObjectId"
        String      notification_id            FK  "-> NOTIF_notifications"
        String      correlation_id             UK  "Unique trace ID"
        String      channel                        "Required"
        String      provider                       "SendGrid|Twilio|FCM|Internal"
        Number      attempt                        "DEFAULT 1 retry counter"
        String      status                         "SUCCESS|FAILED|RETRYING"
        String      provider_response_code         "nullable HTTP code"
        String      provider_message_id            "nullable gateway msg ID"
        String      error_message                  "nullable failure detail"
        Date        sent_at                        "DEFAULT now"
    }

    NOTIF_preferences {
        ObjectId    _id                        PK  "MongoDB auto ObjectId"
        String      user_id                    UK  "logical ref AUTH_users unique per user"
        Map         preferences                    "type_key -> {email|sms|push} boolean map"
        Date        updated_at                     "DEFAULT now"
    }

    NOTIF_push_tokens {
        ObjectId    _id                        PK  "MongoDB auto ObjectId"
        String      user_id                        "logical ref AUTH_users indexed"
        String      token                      UK  "Unique FCM/APNS/Web Push token"
        String      platform                       "WEB|ANDROID|IOS"
        Date        created_at                     "DEFAULT now"
        Date        last_used_at                   "DEFAULT now"
    }

    NOTIF_webhooks {
        ObjectId    _id                        PK  "MongoDB auto ObjectId"
        String      webhook_id                 UK  "UUID"
        String      url                            "Required HTTPS endpoint"
        Array       event_types                    "subscribed Kafka event type names"
        String      secret                         "HMAC signing secret"
        Boolean     is_active                      "DEFAULT true"
        String      created_by                     "logical ref AUTH_users"
        Date        createdAt
        Date        updatedAt
    }


%% ═════════════════════════════════════════════════════════════════════════════
%%  INTRA-SERVICE RELATIONSHIPS  (enforced by DB engine / ORM)
%% ═════════════════════════════════════════════════════════════════════════════

    %% ── Auth Service (MySQL FK-enforced) ─────────────────────────────────────
    AUTH_users             ||--o{ AUTH_user_roles        : "has roles"
    AUTH_roles             ||--o{ AUTH_user_roles        : "granted to users"
    AUTH_roles             ||--o{ AUTH_role_permissions  : "grants permissions"
    AUTH_permissions       ||--o{ AUTH_role_permissions  : "included in roles"
    AUTH_users             ||--o{ AUTH_refresh_tokens    : "owns tokens"
    AUTH_users             ||--o{ AUTH_account_requests  : "submits request"
    AUTH_users             ||--o{ AUTH_audit_log         : "audited in"

    %% ── Event Service (MySQL FK-enforced via JPA) ─────────────────────────────
    EVT_event_categories   ||--o{ EVT_events             : "categorises"
    EVT_events             ||--o{ EVT_event_sessions     : "has sessions"
    EVT_events             ||--o{ EVT_event_agenda       : "has agenda"
    EVT_events             ||--o{ EVT_event_tags         : "tagged with"
    EVT_event_sessions     ||--o{ EVT_event_agenda       : "referenced by"

    %% ── Venue-Vendor Service (MongoDB ref-enforced by Mongoose) ──────────────
    VV_venues              ||--o{ VV_venue_bookings      : "booked via"
    VV_vendors             ||--o{ VV_event_vendors       : "contracted in"

    %% ── Ticketing Service (MongoDB application-enforced) ─────────────────────
    TKT_ticket_types       ||--o{ TKT_registrations      : "purchased as"
    TKT_ticket_types       ||--o{ TKT_waitlists          : "waitlisted for"
    TKT_registrations      ||--|| TKT_tickets            : "issues one ticket"
    TKT_registrations      ||--o{ TKT_checkin_logs       : "checked in via"
    TKT_tickets            ||--o{ TKT_checkin_logs       : "scanned in log"

    %% ── Finance Service (MySQL FK-enforced via EF Core) ──────────────────────
    FIN_budgets            ||--o{ FIN_budget_items       : "broken into items"
    FIN_budgets            ||--o{ FIN_expenses           : "tracks expenses"

    %% ── Notification Service (MongoDB ref-enforced by Mongoose) ──────────────
    NOTIF_notifications    ||--o{ NOTIF_delivery_logs    : "delivered via"


%% ═════════════════════════════════════════════════════════════════════════════
%%  CROSS-SERVICE LOGICAL REFERENCES  (enforced at application layer via IDs)
%%  All services own their own DB; these are NOT foreign keys.
%%  Kafka events + REST calls maintain eventual consistency.
%% ═════════════════════════════════════════════════════════════════════════════

    %% ── Auth → downstream (user_id distributed as JWT claim) ─────────────────
    AUTH_users             ||--o{ EVT_events             : "organizes (logical)"
    AUTH_users             ||--o{ TKT_registrations      : "attends (logical)"
    AUTH_users             ||--o{ FIN_payments           : "pays (logical)"
    AUTH_users             ||--o{ NOTIF_notifications    : "notified (logical)"
    AUTH_users             ||--o{ NOTIF_preferences      : "configures (logical)"
    AUTH_users             ||--o{ NOTIF_push_tokens      : "device registered (logical)"

    %% ── Event → downstream (event_id propagated via Kafka / REST) ────────────
    EVT_events             ||--o{ VV_venue_bookings      : "books venue (logical)"
    EVT_events             ||--o{ VV_event_vendors       : "contracts vendor (logical)"
    EVT_events             ||--o{ TKT_ticket_types       : "offers tickets (logical)"
    EVT_events             ||--o{ TKT_registrations      : "registered for (logical)"
    EVT_events             ||--o{ TKT_feedbacks          : "reviewed in (logical)"
    EVT_events             ||--o{ FIN_budgets            : "budgeted for (logical)"
    EVT_events             ||--o{ FIN_expenses           : "incurs expense (logical)"
    EVT_events             ||--o{ FIN_payments           : "receives payment (logical)"
    EVT_events             ||--o{ FIN_sponsorships       : "sponsored by (logical)"

    %% ── Ticketing → Finance (payment_id written back after gateway callback) ──
    TKT_registrations      ||--o{ FIN_payments           : "paid via (logical)"

    %% ── Venue-Vendor → Finance (vendor sponsors events) ──────────────────────
    VV_vendors             ||--o{ FIN_sponsorships       : "sponsors event (logical)"
